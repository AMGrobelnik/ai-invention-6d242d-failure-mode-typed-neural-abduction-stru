\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Type-B precision recovery results (BM25 ablation, $n=99$). BM25 $k=3$ achieves 90.9\% precision, confirming span-grounded retrieval can prevent Type-B hallucination with minimal recall loss versus unconstrained baselines.}}{10}{table.2}\protected@file@percent }
\newlabel{tab:typeb}{{2}{10}{Type-B precision recovery results (BM25 ablation, $n=99$). BM25 $k=3$ achieves 90.9\% precision, confirming span-grounded retrieval can prevent Type-B hallucination with minimal recall loss versus unconstrained baselines}{table.2}{}}
